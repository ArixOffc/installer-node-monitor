[Unit]
Description=Node Monitoring Agent
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/node-monitoring-agent
ExecStart=/usr/bin/node /opt/node-monitoring-agent/monitor-agent.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
